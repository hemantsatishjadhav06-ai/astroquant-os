# Copy to .env and fill in. Prefix AQ_.
AQ_PG_HOST=localhost
AQ_PG_PORT=5432
AQ_PG_DB=astroquant
AQ_PG_USER=astroquant
AQ_PG_PASSWORD=astroquant
AQ_MONGO_URI=mongodb://localhost:27017
AQ_REDIS_HOST=localhost
AQ_REDIS_PORT=6379
# Ephemeris: leave EPHE_PATH empty to use built-in Moshier model (no data files needed).
AQ_EPHE_PATH=
AQ_AYANAMSA=lahiri
# Market data: yfinance (free fallback) | kite | upstox | smartapi
AQ_BROKER=yfinance
AQ_KITE_API_KEY=
AQ_KITE_API_SECRET=
AQ_KITE_ACCESS_TOKEN=
